# =============================================================================
# PhenoAI Studio — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com valores reais
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=phenoai
POSTGRES_USER=phenoai
# Mínimo 16 caracteres em produção
POSTGRES_PASSWORD=phenoai_secret

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Mínimo 16 caracteres em produção
REDIS_PASSWORD=redis_secret

# ─────────────────────────────────────────────────────────────────────────────
# Kafka
# ─────────────────────────────────────────────────────────────────────────────
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_UI_PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# MinIO (Object Storage)
# ─────────────────────────────────────────────────────────────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
# Mínimo 8 caracteres
MINIO_ROOT_PASSWORD=minio_secret_2024
MINIO_BUCKET_IMAGES=phenoai-images
MINIO_BUCKET_MODELS=phenoai-models

# ─────────────────────────────────────────────────────────────────────────────
# JWT — Auth Service
# ─────────────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
# Access token em segundos (padrão: 1h)
JWT_ACCESS_TOKEN_EXPIRATION=3600
# Refresh token em segundos (padrão: 7d)
JWT_REFRESH_TOKEN_EXPIRATION=604800

# ─────────────────────────────────────────────────────────────────────────────
# Portas dos Microsserviços
# ─────────────────────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
CREDENTIAL_SERVICE_PORT=8083
MODEL_CATALOG_SERVICE_PORT=8084
AI_ORCHESTRATION_SERVICE_PORT=8085
ANALYSIS_SERVICE_PORT=8086

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Idioma padrão: pt-BR | en
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR

# ─────────────────────────────────────────────────────────────────────────────
# Segurança (Criptografia AES-256 — Credential Service)
# ─────────────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AES_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# ─────────────────────────────────────────────────────────────────────────────
# Provedores de IA (preenchidos pelo usuário via UI)
# ─────────────────────────────────────────────────────────────────────────────
# Estas chaves NÃO ficam no .env — são gerenciadas pelo Credential Service
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=...

# ─────────────────────────────────────────────────────────────────────────────
# Observabilidade (Sprint 2+)
# ─────────────────────────────────────────────────────────────────────────────
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001
# LOKI_PORT=3100
# JAEGER_UI_PORT=16686
